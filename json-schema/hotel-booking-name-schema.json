{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Name",
  "description": "Guest Name",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "title/gender of room guest",
      "enum": [
        "MR",
        "MRS",
        "MS"
      ]
    },
    "firstName": {
      "type": "string",
      "description": "first name (and middle name) of room guest"
    },
    "lastName": {
      "type": "string",
      "description": "last name of room guest"
    }
  },
  "required": [
    "firstName",
    "lastName"
  ]
}