{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "email",
  "description": "Email information.",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "description": "Category of the contact element",
      "enum": [
        "BUSINESS",
        "PERSONAL",
        "OTHER"
      ]
    },
    "address": {
      "type": "string",
      "description": "Email address (e.g. john@smith.com)"
    }
  }
}