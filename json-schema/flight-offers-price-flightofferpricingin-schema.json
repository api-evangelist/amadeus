{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlightOfferPricingIn",
  "description": "input parameter to price flight offers element",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "the resource name"
    },
    "flightOffers": {
      "type": "array",
      "description": "list of flight offer to price",
      "items": {
        "$ref": "#/definitions/FlightOffer"
      }
    },
    "payments": {
      "type": "array",
      "description": "payment information for retrieve eventual credit card fees",
      "items": {
        "type": "object",
        "properties": {
          "brand": {
            "$ref": "#/definitions/PaymentBrand"
          },
          "binNumber": {
            "type": "integer",
            "description": "The first 6 digits of the credit card"
          },
          "flightOfferIds": {
            "type": "array",
            "description": "Id of the flightOffers to pay",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "travelers": {
      "type": "array",
      "description": "list of travelers",
      "items": {
        "$ref": "#/definitions/Traveler"
      }
    }
  },
  "required": [
    "type",
    "flightOffers"
  ]
}