{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amadeus/refs/heads/main/json-schema/on-demand-flight-status-arrival-schema.json",
  "title": "Arrival",
  "description": "Arrival schema from On-Demand Flight Status",
  "properties": {
    "terminal": {
      "properties": {
        "code": {
          "description": "the code of the terminal",
          "type": "string",
          "example": 1
        }
      }
    },
    "gate": {
      "properties": {
        "mainGate": {
          "description": "the main gate number",
          "type": "string",
          "example": "10A"
        }
      }
    },
    "timings": {
      "description": "the list of timings",
      "type": "array",
      "items": {
        "properties": {
          "qualifier": {
            "description": "the qualifier of the timing. e.g. STD (stands for Schedule Time Departure)",
            "type": "string",
            "example": "STD"
          },
          "value": {
            "type": "string",
            "format": "date-time",
            "example": "06:00:00"
          },
          "delays": {
            "description": "delays that might be recorded on a timing",
            "type": "array",
            "items": {
              "$ref": "#/definitions/Delay"
            }
          }
        }
      }
    }
  },
  "type": "object"
}