{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amadeus/refs/heads/main/json-schema/flight-offers-search-price-schema.json",
  "title": "Price",
  "description": "Price schema from Flight Offers Search",
  "properties": {
    "currency": {
      "type": "string",
      "example": "USD"
    },
    "total": {
      "description": "Total amount paid by the user",
      "type": "string",
      "example": "932.70"
    },
    "base": {
      "description": "Amount without taxes",
      "type": "string",
      "example": "632.70"
    },
    "fees": {
      "description": "List of applicable fees",
      "type": "array",
      "items": {
        "description": "a fee",
        "properties": {
          "amount": {
            "type": "string",
            "example": "332.70"
          },
          "type": {
            "$ref": "#/definitions/FeeType"
          }
        }
      }
    },
    "taxes": {
      "type": "array",
      "items": {
        "description": "a tax",
        "type": "object",
        "properties": {
          "amount": {
            "type": "string",
            "example": "332.70"
          },
          "code": {
            "type": "string",
            "example": "MX"
          }
        }
      }
    },
    "refundableTaxes": {
      "description": "The amount of taxes which are refundable",
      "type": "string",
      "example": "200.00"
    }
  },
  "type": "object"
}