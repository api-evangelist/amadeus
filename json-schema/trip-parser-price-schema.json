{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "price",
  "description": "Price valuation information",
  "type": "object",
  "properties": {
    "currency": {
      "type": "string",
      "description": "currency Code apply to all elements of the price"
    },
    "total": {
      "type": "string",
      "description": "Total = base + totalTaxes +"
    },
    "base": {
      "type": "string"
    },
    "totalTaxes": {
      "type": "string"
    }
  }
}