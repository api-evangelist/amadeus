{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amadeus/refs/heads/main/json-schema/transfer-book-contact-schema.json",
  "title": "Contact",
  "description": "Contact schema from Transfer Booking",
  "type": "object",
  "properties": {
    "phoneNumber": {
      "type": "string",
      "pattern": "([+]?)[0-9]{1,20}",
      "description": "Contact phone number",
      "example": "+33123456789"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email",
      "example": "traveler@example.com"
    }
  }
}