{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agency",
  "description": "Agency email information.",
  "type": "object",
  "properties": {
    "contacts": {
      "type": "array",
      "description": "List of contact information",
      "items": {
        "type": "object",
        "properties": {
          "email": {
            "type": "object",
            "description": "Email information.",
            "properties": {
              "address": {
                "type": "string",
                "format": "email",
                "description": "Email address (e.g. john@smith.com)"
              }
            }
          }
        }
      }
    }
  }
}