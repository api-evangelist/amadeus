{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amadeus/refs/heads/main/json-schema/seatmap-display-fee-schema.json",
  "title": "Fee",
  "description": "a fee",
  "properties": {
    "amount": {
      "type": "string",
      "example": "332.70"
    },
    "type": {
      "type": "string",
      "description": "type of fee",
      "enum": [
        "TICKETING",
        "FORM_OF_PAYMENT",
        "SUPPLIER"
      ],
      "example": "TICKETING"
    }
  },
  "type": "object"
}