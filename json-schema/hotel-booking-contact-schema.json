{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contact",
  "description": "Contact Details",
  "type": "object",
  "properties": {
    "phone": {
      "type": "string",
      "description": "Phone Number in standard E.123(https://en.wikipedia.org/wiki/E.123)"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email Address"
    }
  },
  "required": [
    "phone",
    "email"
  ]
}