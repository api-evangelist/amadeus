{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HotelSentiment",
  "type": "object",
  "properties": {
    "hotelId": {
      "type": "string",
      "description": "Amadeus Hotel Ids are found in the Hotel Search response (parameter name is 'hotelId')"
    },
    "type": {
      "type": "string"
    },
    "overallRating": {
      "$ref": "#/definitions/Score"
    },
    "numberOfRatings": {
      "type": "integer"
    },
    "numberOfReviews": {
      "type": "integer"
    },
    "sentiments": {
      "type": "object",
      "description": "Dictionary containing scores for all the available categories.  If a property does not have any category this object will not be present in the response.",
      "properties": {
        "sleepQuality": {
          "$ref": "#/definitions/Score"
        },
        "service": {
          "$ref": "#/definitions/Score"
        },
        "facilities": {
          "$ref": "#/definitions/Score"
        },
        "roomComforts": {
          "$ref": "#/definitions/Score"
        },
        "valueForMoney": {
          "$ref": "#/definitions/Score"
        },
        "catering": {
          "$ref": "#/definitions/Score"
        },
        "swimmingPool": {
          "$ref": "#/definitions/Score"
        },
        "location": {
          "$ref": "#/definitions/Score"
        },
        "internet": {
          "$ref": "#/definitions/Score"
        },
        "pointsOfInterest": {
          "$ref": "#/definitions/Score"
        },
        "staff": {
          "$ref": "#/definitions/Score"
        }
      }
    }
  },
  "required": [
    "hotelId",
    "overallRating",
    "avgHotelAvailabilityResponseTime",
    "numberOfRatings",
    "numberOfReviews"
  ]
}