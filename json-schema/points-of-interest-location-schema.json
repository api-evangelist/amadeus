{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Location",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "id of the ressource"
    },
    "self": {
      "$ref": "#/definitions/Links"
    },
    "type": {
      "type": "string",
      "description": "the resource name"
    },
    "subType": {
      "type": "string",
      "description": "location sub type",
      "enum": [
        "AIRPORT",
        "CITY",
        "POINT_OF_INTEREST",
        "DISTRICT"
      ]
    },
    "name": {
      "type": "string",
      "description": "short name of the location"
    },
    "geoCode": {
      "$ref": "#/definitions/GeoCode"
    },
    "category": {
      "type": "string",
      "description": "category of the location",
      "enum": [
        "SIGHTS",
        "BEACH_PARK",
        "HISTORICAL",
        "NIGHTLIFE",
        "RESTAURANT",
        "SHOPPING"
      ]
    },
    "tags": {
      "type": "array",
      "description": "list of tags related to the location",
      "items": {
        "type": "string"
      }
    },
    "rank": {
      "type": "string",
      "description": "the rank is the position compared to other locations based on how famous is a place. 1 being the highest."
    }
  }
}