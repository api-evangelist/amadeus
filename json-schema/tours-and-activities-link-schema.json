{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Link",
  "type": "object",
  "properties": {
    "href": {
      "type": "string",
      "format": "uri"
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "GET",
          "PUT",
          "DELETE",
          "POST",
          "PATCH"
        ]
      }
    }
  }
}