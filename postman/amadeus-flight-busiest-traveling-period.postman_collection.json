                            "value": "application/vnd.amadeus+json"
                          }
                        ],
                        "url": {
                          "raw": "{{baseUrl}}/travel/analytics/air-traffic/busiest-period?cityCode=hsS&period=<string>&direction=ARRIVING",
                          "host": [
                            "{{baseUrl}}"
                          ],
                          "path": [
                            "travel",
                            "analytics",
                            "air-traffic",
                            "busiest-period"
                          ],
                          "query": [
                            {
                              "description": "(Required) Code for the city following IATA standard. [IATA table codes](http://www.iata.org/publications/Pages/code-search.aspx) - e.g. BOS for Boston",
                              "key": "cityCode",
                              "value": "hsS"
                            },
                            {
                              "description": "(Required) time period (year) of the statistics.\n\nYear for which the statistic are requested following [ISO 8601](https://en.wikipedia.org/wiki/ISO_8601)\n",
                              "key": "period",
                              "value": "<string>"
                            },
                            {
                              "description": "Use ARRIVING to have statistics on travelers coming to the city or DEPARTING for statistics on travelers leaving the city.\n\nBy default, statistics are given on travelers ARRIVING the city.\n",
                              "key": "direction",
                              "value": "ARRIVING"
                            }
                          ]
                        }
