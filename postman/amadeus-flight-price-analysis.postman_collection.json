              "protocolProfileBehavior": {
                "disableBodyPruning": true
              },
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/vnd.amadeus+json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/analytics/itinerary-price-metrics?originIataCode=Lbt&destinationIataCode=Lbt&departureDate=<string>&currencyCode=EUR&oneWay=false",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "analytics",
                    "itinerary-price-metrics"
                  ],
                  "query": [
                    {
                      "description": "(Required) airport code, following [IATA standard](http://www.iata.org/publications/Pages/code-search.aspx), from which the traveler will depart\n",
                      "key": "originIataCode",
                      "value": "Lbt"
                    },
                    {
                      "description": "(Required) airport code, following [IATA standard](http://www.iata.org/publications/Pages/code-search.aspx), to which the traveler is going.",
                      "key": "destinationIataCode",
                      "value": "Lbt"
                    },
                    {
                      "description": "(Required) The date on which the traveler will depart from the origin to go to the destination. \n\nDates are specified in the[ISO 8601](https://en.wikipedia.org/wiki/ISO_8601) YYYY-MM-DD format.",
                      "key": "departureDate",
                      "value": "<string>"
                    },
                    {
                      "description": "the preferred currency for display. Currency is specified in the [ISO 4217](https://en.wikipedia.org/wiki/ISO_4217) format, e.g. EUR for Euro",
                      "key": "currencyCode",
                      "value": "EUR"
                    },
                    {
                      "description": "true to get price metrics for a one way trip,\nfalse to get price metrics for a round trip",
                      "key": "oneWay",
                      "value": "false"
                    }
                  ]
                }
              },
