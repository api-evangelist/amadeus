              "name": "air-traffic",
              "item": [
                {
                  "name": "traveled",
                  "item": [
                    {
                      "name": "Amadeus Returns a List of Air Traffic Reports.",
                      "id": "087da8c0-fbe0-4e38-bd43-4accb1cf1fa4",
                      "protocolProfileBehavior": {
                        "disableBodyPruning": true
                      },
                      "request": {
                        "method": "GET",
                        "header": [
                          {
                            "key": "Accept",
                            "value": "application/vnd.amadeus+json"
                          }
                        ],
                        "url": {
                          "raw": "{{baseUrl}}/travel/analytics/air-traffic/traveled?originCityCode=Tza&period=<string>&max=10&fields=<string>&page[limit]=10&page[offset]=0&sort=analytics.travelers.score",
                          "host": [
                            "{{baseUrl}}"
                          ],
                          "path": [
                            "travel",
                            "analytics",
                            "air-traffic",
                            "traveled"
                          ],
                          "query": [
                            {
                              "description": "(Required) Code for the origin city following IATA standard ([IATA table codes](http://www.iata.org/publications/Pages/code-search.aspx)). - e.g. BOS for Boston",
                              "key": "originCityCode",
                              "value": "Tza"
                            },
                            {
                              "description": "(Required) period when consumers are traveling.\n* It can be a month only. \n* [ISO 8601](https://en.wikipedia.org/wiki/ISO_8601) format must be used - e.g. 2015-05. \n* Period ranges are not supported. \n* Only periods from 2011-01 up to previous month are valid. \n* Future dates are not supported.\n",
                              "key": "period",
                              "value": "<string>"
                            },
                            {
                              "description": "maximum number of destinations in the response. Default value is **10** and maximum value is 50.",
                              "key": "max",
                              "value": "10"
                            },
                            {
                              "description": "list of attributes desired in the response or list of attributes to remove from the response (with \"-\" before fields) \n* The attributes names must contain the whole path (except resource name) e.g. travelers",
                              "key": "fields",
                              "value": "<string>"
                            },
                            {
                              "description": "maximum items in one page",
                              "key": "page[limit]",
                              "value": "10"
                            },
                            {
                              "description": "start index of the requested page",
                              "key": "page[offset]",
                              "value": "0"
                            },
                            {
                              "description": "defines on which attribute the sorting will be done:\n* **analytics.flights.score** - sort destination by flights score (decreasing)\n* **analytics.travelers.score** - sort destination by traveler's score (decreasing)\n",
                              "key": "sort",
                              "value": "analytics.travelers.score"
                            }
                          ]
                        }
                      },
