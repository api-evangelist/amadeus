                          "key": "arrivalTime",
                          "value": "<time>"
                        },
                        {
                          "description": "(Required) IATA aircraft code (http://www.flugzeuginfo.net/table_accodes_iata_en.php)",
                          "key": "aircraftCode",
                          "value": "czy"
                        },
                        {
                          "description": "(Required) airline / carrier code",
                          "key": "carrierCode",
                          "value": "<string>"
                        },
                        {
                          "description": "(Required) flight number as assigned by the carrier",
                          "key": "flightNumber",
