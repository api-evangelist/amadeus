  "info": {
    "_postman_id": "c6b6037b-95eb-4d49-9363-9ac44b3a21b4",
    "name": "Amadeus OAuth2 Login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Amadeus for Developers uses OAuth2 to authenticate access requests. OAuth2 generates an access token which grants the client permission to access a protected resource. The method to acquire a token is called grant. There are different types of OAuth2 grants. Amadeus for Developers uses the Client Credentials Grant.\n  https://developers.amadeus.com/self-service/apis-docs/guides/authorization-262\n",
      "type": "text/plain"
    }
  }
