          "id": "1ce67bd1-2f8f-459d-8f54-7e03c622771b",
          "name": "Amadeus Returns a List of Airports and Cities Matching a Given Keyword.",
          "request": {
            "name": "Amadeus Returns a List of Airports and Cities Matching a Given Keyword.",
            "description": {
              "content": "",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "reference-data",
                "locations"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "subType",
                  "value": "<string>,<string>",
                  "description": "(Required) sub type of the location (AIRPORT and/or CITY)"
                },
                {
                  "disabled": false,
                  "key": "keyword",
                  "value": "<string>",
                  "description": "(Required) keyword that should represent the start of a word in a city or airport name or code. \nSupported charaters are: A-Za-z0-9./:-'()\""
                },
                {
                  "disabled": false,
                  "key": "countryCode",
                  "value": "<string>",
                  "description": "Country code of the location using [ISO 3166-1 alpha-2](https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code format (e.g. US)."
                },
                {
                  "disabled": false,
                  "key": "page[limit]",
                  "value": "10",
                  "description": "maximum items in one page"
                },
                {
                  "disabled": false,
                  "key": "page[offset]",
                  "value": "0",
                  "description": "start index of the requested page"
                },
                {
                  "disabled": false,
                  "key": "sort",
                  "value": "analytics.travelers.score",
                  "description": "defines on which attribute the sorting will be done:\n* analytics.travelers.score - sort by the number of travelers by airport or city, the airports and cities with the highest traffic are on top of the results\n"
                },
                {
                  "disabled": false,
                  "key": "view",
                  "value": "FULL",
                  "description": "select the level of information of the reply:\n* LIGHT - Gives only the IATACode, name, detailedName, cityName and countryName\n* FULL - Adds on top of the LIGHT information the timeZoneOffset, geocode, detailed address and travelers.score\ndefault option is FULL\n"
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.amadeus+json"
              }
            ],
            "method": "GET",
            "auth": null
