{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "type": {
      "@id": "schema:type",
      "@type": "xsd:string"
    },
    "id": {
      "@id": "@id"
    },
    "href": {
      "@id": "schema:href",
      "@type": "@id"
    },
    "channel": {
      "@id": "schema:channel",
      "@type": "xsd:string"
    },
    "parameters": {
      "@id": "schema:parameters",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description"
    },
    "format": {
      "@id": "schema:format",
      "@type": "xsd:string"
    },
    "errors": {
      "@id": "schema:errors"
    }
  }
}