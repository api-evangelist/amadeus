{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "type": {
      "@id": "schema:type",
      "@type": "xsd:string"
    },
    "origin": {
      "@id": "schema:origin"
    },
    "destination": {
      "@id": "schema:destination"
    },
    "departureDate": {
      "@id": "schema:departureDate",
      "@type": "xsd:string"
    },
    "transportType": {
      "@id": "schema:transportType",
      "@type": "xsd:string"
    },
    "currencyCode": {
      "@id": "schema:currencyCode",
      "@type": "xsd:string"
    },
    "oneWay": {
      "@id": "schema:oneWay",
      "@type": "xsd:boolean"
    },
    "priceMetrics": {
      "@id": "schema:priceMetrics"
    },
    "errors": {
      "@id": "schema:errors"
    }
  }
}