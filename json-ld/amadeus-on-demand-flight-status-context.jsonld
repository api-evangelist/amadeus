{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "type": {
      "@id": "schema:type",
      "@type": "xsd:string"
    },
    "scheduledDepartureDate": {
      "@id": "schema:scheduledDepartureDate",
      "@type": "xsd:date"
    },
