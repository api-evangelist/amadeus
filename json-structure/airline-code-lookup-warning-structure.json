{
  "$schema": "https://json-structure.org/draft/v0/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amadeus/refs/heads/main/json-structure/airline-code-lookup-warning-structure.json",
  "title": "Warning",
  "description": "Warning structure from Airline Code Lookup API",
  "type": "object",
  "properties": {
    "code": {
      "type": "integer",
      "format": "int64",
      "description": "an application-specific error code"
    },
    "title": {
      "type": "string",
      "description": "a short summary of the error"
    },
    "detail": {
      "type": "string",
      "description": "explanation of the error"
    },
    "source": {
      "type": "object",
      "description": "an object containing references to the source of the error"
    }
  }
}