{
  "$schema": "https://json-structure.org/meta/extended/v0/#",
  "name": "Location",
  "type": "record",
  "fields": [
    {
      "name": "id",
      "type": "string",
      "description": "id of the ressource"
    },
    {
      "name": "self",
      "type": "string"
    },
    {
      "name": "type",
      "type": "string",
      "description": "the resource name"
    },
    {
      "name": "subType",
      "type": "string",
      "description": "location sub type"
    },
    {
      "name": "name",
      "type": "string",
      "description": "short name of the location"
    },
    {
      "name": "geoCode",
      "type": "string"
    },
    {
      "name": "category",
      "type": "string",
      "description": "category of the location"
    },
    {
      "name": "tags",
      "type": "array",
      "description": "list of tags related to the location",
      "items": {
        "type": "string"
      }
    },
    {
      "name": "rank",
      "type": "string",
      "description": "the rank is the position compared to other locations based on how famous is a place. 1 being the highest."
    }
  ]
}