      "description": "office Id where will be transfered the ownership of the order"
    },
    {
      "name": "associatedRecords",
      "type": "array",
      "description": "list of associated record",
      "items": {
        "type": "object"
      }
    },
    {
      "name": "flightOffers",
      "type": "array",
      "description": "list of flight offer",
      "items": {
        "type": "object"
      }
    },
    {
      "name": "travelers",
